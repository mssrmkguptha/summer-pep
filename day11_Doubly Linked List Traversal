class Solution {
  public:
    vector<vector<int>> displayList(Node *head) {
       vector<vector<int>>ans;
       Node* temp=head;
       vector<int>f;
       while(temp->next!=NULL){
           f.push_back(temp->data);
           temp=temp->next;
       }
       f.push_back(temp->data);
       ans.push_back(f);
       vector<int>b;
       while(temp!=NULL){
           b.push_back(temp->data);
           temp=temp->prev;
       }
       ans.push_back(b);
       return ans;
    }



};
