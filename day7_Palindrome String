class Solution {
  public:
    bool isPalindrome(string& s) {
        stack<char> st;
        
        for(int i=0;i<s.size();i++){
            st.push(s[i]);
        }
        for(int i=0;i<s.size();i++){
            if(s[i]!=st.top()) return 0;
            
            st.pop();
        }
        return 1;
    }
};
