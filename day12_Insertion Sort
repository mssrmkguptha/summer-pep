class Solution {
  public:
    void insertionSort(vector<int>& arr) {
        
        int n=arr.size();
        for(int i=1;i<n;i++){
            
            int x=arr[i];
           int j=i-1;
            while(j>=0 and x < arr[j]){
                arr[j+1]=arr[j];
                j--;
            }
            arr[j+1]=x;
        }
        
    }
};
