class Solution {
public:
int mx=0;
int dia(TreeNode* root){
    if(!root) return 0;
    int l=dia(root->left);
     int r=dia(root->right);
     mx=max(mx,l+r);
     return 1+max(l,r);

}
  int diameterOfBinaryTree(TreeNode* root) {
            int x=dia(root);
            return mx;
        

    }
};
