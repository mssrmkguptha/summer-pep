class Solution {
  public:
    int findMax(Node *root) {
        if(!root) return -1e9;
        int l=findMax(root->left);
        int r=findMax(root->right);
        return max(root->data,max(l,r));
    }

    int findMin(Node *root) {
        if(!root) return 1e9;
        int l=findMin(root->left);
        int r=findMin(root->right);
        return min(root->data,min(l,r));
   
    }
};
