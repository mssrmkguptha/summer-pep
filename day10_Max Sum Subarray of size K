class Solution {
  public:
    int maxSubarraySum(vector<int>& arr, int k) {

        int n=arr.size();
        int i=0,j=0;
        int sum=0,mx=0;
        while(j<n){
          
          sum+=arr[j];
          
          if(j-i+1<k) j++;
          else if(j-i+1==k){
              mx=max(mx,sum);
              
              sum-=arr[i];
              
              j++;i++;
          }
        }
        return mx;
    }
};
